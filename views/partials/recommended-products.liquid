<section class="recommended-products">

    <h2>Our recommended products</h2>

    <ul class="product-list">
        
        {% for number in (1..5) %} 

            <li class="product-card">

                <span class="product-badge">
                    Sale
                </span>

                <div class="dummy-img">
                    
                </div>

                <div class="recommended-product-content">
                    <h3 class="product-title">
                        FORCLAZ 2-person trekking dome tent
                    </h3>

                    <div class="product-rating">
                        ★★★★★ (8888)
                    </div>

                    <p class="product-colours">
                        4 colours
                    </p>

                    <p class="product-seller">
                        Sold & shipped by Pacific Camping UK
                    </p>

                    <p class="recommended-product-price">
                        £00.00
                    </p>
                </div>

            </li>

        {% endfor %}  

    </ul>

    <div class="scroll-indicator">
        <span class="scroll-indicator-progress"></span>
    </div>

</section>