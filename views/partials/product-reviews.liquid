<section class="product-reviews">
    <div class="form-wrapper">
        <form id="" class="review-form" method="POST" action="/reviews">
            <h2>Write a review</h2>

            <label for="review-title">Titel</label>
            <input type="text" id="review-title" name="review-title" required>

            <p class="error-message review-title-error-message"></p>

            <label for="review-description">Review</label>
            <textarea 
                id="review-description" 
                name="review-description" 
                rows="5" 
                maxlength="250"
                required></textarea>

            <p class="error-message review-description-error-message"></p>

            <p class="review-character-count">0 / 500</p>

            <label for="reviewer-name">Name</label>
            <input type="text" id="reviewer-name" name="reviewer-name" required>

            <p class="error-message reviewer-name-error-message"></p>

            <fieldset class="overall-rating">
                <legend>Overall rating</legend>

                <div class="star-rating">

                    <input type="radio" id="rating-5" name="rating" value="5" required>
                    <label for="rating-5">★</label>

                    <input type="radio" id="rating-4" name="rating" value="4">
                    <label for="rating-4">★</label>

                    <input type="radio" id="rating-3" name="rating" value="3">
                    <label for="rating-3">★</label>

                    <input type="radio" id="rating-2" name="rating" value="2">
                    <label for="rating-2">★</label>

                    <input type="radio" id="rating-1" name="rating" value="1">
                    <label for="rating-1">★</label>

                </div>
            </fieldset>

            <h3 class="feature-ratings-title">Feature ratings</h3>

            <p class="feature-ratings-description">Rate the product features based on your experience.</p>

            <fieldset class="feature-rating">
                <legend>Grip</legend>

                <div class="star-rating">

                    <input type="radio" id="grip-rating-5" name="grip-rating" value="5" required>
                    <label for="grip-rating-5">★</label>

                    <input type="radio" id="grip-rating-4" name="grip-rating" value="4">
                    <label for="grip-rating-4">★</label>

                    <input type="radio" id="grip-rating-3" name="grip-rating" value="3">
                    <label for="grip-rating-3">★</label>

                    <input type="radio" id="grip-rating-2" name="grip-rating" value="2">
                    <label for="grip-rating-2">★</label>

                    <input type="radio" id="grip-rating-1" name="grip-rating" value="1">
                    <label for="grip-rating-1">★</label>

                </div>
            </fieldset>

            <fieldset class="feature-rating">
                <legend>Foot support</legend>

                <div class="star-rating">

                    <input type="radio" id="foot-support-rating-5" name="foot-support-rating" value="5" required>
                    <label for="foot-support-rating-5">★</label>

                    <input type="radio" id="foot-support-rating-4" name="foot-support-rating" value="4">
                    <label for="foot-support-rating-4">★</label>

                    <input type="radio" id="foot-support-rating-3" name="foot-support-rating" value="3">
                    <label for="foot-support-rating-3">★</label>

                    <input type="radio" id="foot-support-rating-2" name="foot-support-rating" value="2">
                    <label for="foot-support-rating-2">★</label>

                    <input type="radio" id="foot-support-rating-1" name="foot-support-rating" value="1">
                    <label for="foot-support-rating-1">★</label>

                </div>
            </fieldset>

            <fieldset class="feature-rating">
                <legend>Lightweight</legend>

                <div class="star-rating">

                    <input type="radio" id="lightweight-rating-5" name="lightweight-rating" value="5" required>
                    <label for="lightweight-rating-5">★</label>

                    <input type="radio" id="lightweight-rating-4" name="lightweight-rating" value="4">
                    <label for="lightweight-rating-4">★</label>

                    <input type="radio" id="lightweight-rating-3" name="lightweight-rating" value="3">
                    <label for="lightweight-rating-3">★</label>

                    <input type="radio" id="lightweight-rating-2" name="lightweight-rating" value="2">
                    <label for="lightweight-rating-2">★</label>

                    <input type="radio" id="lightweight-rating-1" name="lightweight-rating" value="1">
                    <label for="lightweight-rating-1">★</label>

                </div>
            </fieldset>

            <fieldset class="feature-rating">
                <legend>Cushioning</legend>

                <div class="star-rating">

                    <input type="radio" id="cushioning-rating-5" name="cushioning-rating" value="5" required>
                    <label for="cushioning-rating-5">★</label>

                    <input type="radio" id="cushioning-rating-4" name="cushioning-rating" value="4">
                    <label for="cushioning-rating-4">★</label>

                    <input type="radio" id="cushioning-rating-3" name="cushioning-rating" value="3">
                    <label for="cushioning-rating-3">★</label>

                    <input type="radio" id="cushioning-rating-2" name="cushioning-rating" value="2">
                    <label for="cushioning-rating-2">★</label>

                    <input type="radio" id="cushioning-rating-1" name="cushioning-rating" value="1">
                    <label for="cushioning-rating-1">★</label>

                </div>
            </fieldset>

            <button type="submit" class="submit-review-button">Send review</button>
        </form>
    </div>

    <section class="review-list">
        <h2 class="review-list-title">Reviews</h2>
        {% for review in reviews %}
            <article class="review-card">
                <p>{{ review.rating }}/5 ★</p>
                <h3>{{ review.title }}</h3>
                <p>{{ review.description }}</p>
                
            </article>
        {% endfor %}
    </section>

</section>
