<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Decathlon</title>
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/styleguide.css">
</head>
<body>
    <header>

        <div class="shipping-info">
            <p>Free delivery on orders over €60</p>
        </div>

        <nav class="navbar">

            <button type="button" class="menu-button">
                <img src="" alt="Menu" width="25" height="25">
            </button>

            <a href="/" class="logo">
                <img src="/assets/images/decathlon-logo.svg" alt="Decathlon logo">
            </a>

            <form class="search-form">
                <input type="search" name="search" placeholder="What are you looking for?">
            </form>

            <ul class="header-actions">

                <li class="help-item">
                    <a href="/" aria-label="Help">
                        <img src="" alt="Help" width="25" height="25">
                    </a>
                </li>

                <li class="account-item">
                    <a href="/" aria-label="Account">
                        <img src="" alt="Account" width="25" height="25">
                    </a>
                </li>

                <li class="wishlist-item">
                    <a href="/" aria-label="Wishlist">
                        <img src="" alt="Wishlist" width="25" height="25">
                    </a>
                </li>

                <li class="basket-item">
                    <a href="/" aria-label="Basket">
                        <img src="" alt="Basket" width="25" height="25">
                    </a>
                </li>

            </ul>
        </nav>
    </header>
</body> 
</html>